{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  addLabels: [
    'dependencies',
  ],
  commitMessagePrefix: '‚¨ÜÔ∏è(deps): ',
  extends: [
    // `config:best-practices` bundles config:recommended + helpers:pinGitHubActionDigests + docker:pinDigests
    // + :configMigration + :pinDevDependencies + security:minimumReleaseAgeNpm + :maintainLockFilesWeekly
    // + abandonments:recommended. The `:pinAllExceptPeerDependencies` preset escalates pinning from
    // best-practices' devDeps-only default to "everything except `peerDependencies` and `engines`".
    'config:best-practices',
    ':pinAllExceptPeerDependencies',
  ],
  timezone: 'Asia/Tokyo',
  // Mitigate supply-chain attacks by only considering versions that have been released for at least 1 week.
  minimumReleaseAge: '7 days',
  // Suppress branch/PR creation while a version is still inside the minimumReleaseAge window.
  //   cf. https://docs.renovatebot.com/key-concepts/minimum-release-age/#recommended-settings
  internalChecksFilter: 'strict',
  // Use the OSV database (osv.dev) for vulnerability alerts in addition to the GitHub Advisory Database.
  osvVulnerabilityAlerts: true,
  vulnerabilityAlerts: {
    // Bypass minimumReleaseAge for security alerts (CVEs) so they are applied immediately.
    minimumReleaseAge: '0 days',
  },
  packageRules: [
    {
      // `security:minimumReleaseAgeNpm` (pulled in via `config:best-practices`) sets the npm cooldown to
      // 3 days. Override back to 7 days so npm shares the same cooldown invariant as every other datasource.
      matchDatasources: [
        'npm',
      ],
      minimumReleaseAge: '7 days',
    },
    {
      // Suppress digest-only update PRs. `helpers:pinGitHubActionDigests` (pulled in via `config:best-practices`)
      // pins action references to SHAs and then keeps proposing digest bumps, but every new digest commit is by
      // definition freshly published, so it can never satisfy the 7-day `minimumReleaseAge` window ‚Äî the PR
      // perpetually sits in pending and gets superseded by the next digest before it ages out. The defenses we
      // still have:
      //   - The SHA pin itself (deps are immutable between bumps)
      //   - Real version bumps (major/minor/patch) still flow and are subject to the normal 7-day cooldown
      //   - CVE-tracked issues bypass cooldown via `vulnerabilityAlerts`
      matchDepTypes: [
        'action',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      enabled: false,
    },
    {
      // Disable scheduled lockFileMaintenance for cargo. The maintenance step delegates to `cargo update`,
      // which has no native release-age filter, so the weekly run would silently pull in transitive versions
      // that are still inside the 7-day `minimumReleaseAge` window. Direct dependency bumps still flow through
      // Renovate's regular PRs (which respect cooldown) and refresh Cargo.lock as part of that work; CVE-tracked
      // transitives bypass cooldown via `vulnerabilityAlerts`. The trade-off is slower transitive refresh,
      // which we accept in exchange for keeping the cooldown invariant.
      matchManagers: [
        'cargo',
      ],
      lockFileMaintenance: {
        enabled: false,
      },
    },
  ],
}
