{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  addLabels: [
    'dependencies',
  ],
  commitMessagePrefix: 'â¬†ď¸Ź(deps): ',
  extends: [
    // `config:best-practices` bundles config:recommended + helpers:pinGitHubActionDigests + docker:pinDigests
    // + :configMigration + :pinDevDependencies + security:minimumReleaseAgeNpm + :maintainLockFilesWeekly
    // + abandonments:recommended. This crate is a library, so we stay on the bundled `:pinDevDependencies`
    // default â€” pinning direct dependencies would force exact versions on downstream consumers.
    'config:best-practices',
  ],
  timezone: 'Asia/Tokyo',
  // Mitigate supply-chain attacks by only considering versions that have been released for at least 1 week.
  minimumReleaseAge: '7 days',
  // Suppress branch/PR creation while a version is still inside the minimumReleaseAge window.
  //   cf. https://docs.renovatebot.com/key-concepts/minimum-release-age/#recommended-settings
  internalChecksFilter: 'strict',
  // Use the OSV database (osv.dev) for vulnerability alerts in addition to the GitHub Advisory Database.
  osvVulnerabilityAlerts: true,
  vulnerabilityAlerts: {
    // Bypass minimumReleaseAge for security alerts (CVEs) so they are applied immediately.
    minimumReleaseAge: '0 days',
  },
  packageRules: [
    {
      // `security:minimumReleaseAgeNpm` (pulled in via `config:best-practices`) sets the npm cooldown to
      // 3 days. Override back to 7 days so npm shares the same cooldown invariant as every other datasource.
      matchDatasources: [
        'npm',
      ],
      minimumReleaseAge: '7 days',
    },
    {
      // Pin / pinDigest / replacement updates do not introduce new code: pin converts an existing
      // range to an exact version, pinDigest fixes an existing action reference to a SHA, and
      // replacement swaps to a maintained successor at an already-allowed version. The release-age
      // check is irrelevant in all three cases â€” and worse, the pin / pinDigest paths don't wire in
      // the release timestamp at all, so any non-null `minimumReleaseAge` leaves the check in
      // pending status forever (with default `minimumReleaseAgeBehaviour: 'timestamp-required'`).
      // Setting it to `null` disables the check rather than just lowering the threshold.
      // `security:minimumReleaseAgeNpm` (pulled in via `config:best-practices`) does the equivalent
      // for npm only; this rule covers the rest.
      matchUpdateTypes: [
        'pin',
        'pinDigest',
        'replacement',
      ],
      minimumReleaseAge: null,
    },
    {
      // Suppress all digest update PRs. `helpers:pinGitHubActionDigests` and `docker:pinDigests` (both
      // pulled in via `config:best-practices`) pin references to SHAs and then keep proposing digest bumps,
      // but every new digest commit is by definition freshly published, so it can never satisfy the 7-day
      // `minimumReleaseAge` window â€” and the digest update path doesn't wire in the release timestamp
      // anyway, so the check would stay in pending status forever regardless of the configured value.
      // Cooldown is structurally unavailable for digest updates, so we suppress them entirely. The
      // defenses we still have:
      //   - The SHA pin itself (deps are immutable between bumps)
      //   - Real version bumps (major/minor/patch) still flow and are subject to the normal 7-day cooldown
      //   - CVE-tracked issues bypass cooldown via `vulnerabilityAlerts`
      matchUpdateTypes: [
        'digest',
      ],
      enabled: false,
    },
    {
      // Disable scheduled lockFileMaintenance for cargo. The maintenance step delegates to `cargo update`,
      // which has no native release-age filter, so the weekly run would silently pull in transitive versions
      // that are still inside the 7-day `minimumReleaseAge` window. Direct dependency bumps still flow through
      // Renovate's regular PRs (which respect cooldown) and refresh Cargo.lock as part of that work; CVE-tracked
      // transitives bypass cooldown via `vulnerabilityAlerts`. The trade-off is slower transitive refresh,
      // which we accept in exchange for keeping the cooldown invariant.
      matchManagers: [
        'cargo',
      ],
      lockFileMaintenance: {
        enabled: false,
      },
    },
  ],
}
